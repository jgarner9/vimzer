{
  "manifest_version": 3,
  "name": "Vimzer",
  "version": "1.1.0",
  "description": "Personal vim-style keyboard navigation: two-letter hint jumps plus scroll focus with Ctrl+D/U and gg/G.",
  "permissions": ["activeTab", "storage", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["hints.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vimzer"
  },
  "commands": {
    "activate-hints": {
      "suggested_key": {
        "mac": "Alt+F",
        "default": "Alt+J"
      },
      "description": "Activate hint mode"
    },
    "activate-hints-new-tab": {
      "suggested_key": {
        "mac": "Alt+Shift+F",
        "default": "Alt+Shift+F"
      },
      "description": "Activate hint mode (open links in new tab)"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
